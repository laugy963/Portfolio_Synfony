# Variables d'environnement pour les tests automatisés
KERNEL_CLASS='App\Kernel'
APP_SECRET=test-secret

# Base de données dédiée aux tests
# Pour forcer une base spécifique en CI, définir TEST_DATABASE_URL.

# Configuration du mailer pour les tests (null = pas d'envoi réel)
MAILER_DSN=null://null
MAILER_FROM_EMAIL=test@example.com
MAILER_FROM_NAME="Test Service"
