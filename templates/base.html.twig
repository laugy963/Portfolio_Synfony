<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Portfolio{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>sf</text></svg>">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="description" content="{% block meta_description %}Portfolio de developpement web Symfony, PHP et frontend leger.{% endblock %}">
        <link rel="canonical" href="{% block canonical_url %}{{ app.request.uri }}{% endblock %}">
        <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
        <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
        <meta property="og:type" content="{% block og_type %}website{% endblock %}">
        <meta property="og:url" content="{{ app.request.uri }}">
        <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('images/banners/banner-1-home.png')) }}{% endblock %}">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% include '_navbar.html.twig' %}

        <main class="{% block main_class %}main-content{% endblock %}">
            {% block body %}{% endblock %}
        </main>

        {% include '_footer.html.twig' %}

        <div id="cookie-banner" class="cookie-banner" hidden>
            <p class="cookie-banner__text">
                Ce site utilise des cookies fonctionnels pour ameliorer votre navigation.
                <a href="{{ path('app_privacy_policy') }}" class="cookie-banner__link">En savoir plus</a>
            </p>
            <div class="cookie-banner__actions">
                <button id="cookie-accept" type="button" class="btn btn-primary btn-sm">Accepter</button>
                <button id="cookie-refuse" type="button" class="btn btn-outline-light btn-sm">Refuser</button>
            </div>
        </div>

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </body>
</html>
