{% extends 'base.html.twig' %}

{% block title %}Nouveau projet{% endblock %}
{% block meta_description %}Creation securisee d un nouveau projet dans l administration du portfolio.{% endblock %}

{% block body %}
    <div class="container page-container project-form-page">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h1 class="h2 mb-1"><i class="fas fa-plus-circle me-2 text-primary"></i>Creer un nouveau projet</h1>
                <p class="text-muted mb-0">Utilisez le formulaire Symfony avec validation serveur et gestion securisee des medias.</p>
            </div>
        </div>

        {% include 'project/_form.html.twig' with {
            form: form,
            project: project,
            button_label: 'Creer le projet'
        } %}
    </div>
{% endblock %}
