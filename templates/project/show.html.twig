{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} | Admin{% endblock %}

{% block body %}
    {% set fallbackProjectImage = asset('images/projects/default-project.svg') %}

    <div class="container page-container">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h1 class="h2 mb-1">{{ project.title }}</h1>
                <p class="text-muted mb-0">Vue detaillee cote administration.</p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('app_project_edit', {id: project.id}) }}" class="btn btn-warning">Modifier</a>
                <a href="{{ path('app_project_index') }}" class="btn btn-secondary">Retour a la liste</a>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <img
                    src="{{ project.bannerImage ? asset('uploads/images/' ~ project.bannerImage) : fallbackProjectImage }}"
                    alt="Banniere du projet {{ project.title }}"
                    class="img-fluid rounded mb-4"
                    width="1200"
                    height="675"
                >

                <dl class="row mb-0">
                    <dt class="col-sm-3">Description courte</dt>
                    <dd class="col-sm-9">{{ project.smallDescription ?: 'Aucune' }}</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">{{ project.description|nl2br }}</dd>

                    <dt class="col-sm-3">Technologies</dt>
                    <dd class="col-sm-9">{{ project.technologies ?: 'Aucune' }}</dd>

                    <dt class="col-sm-3">Realise par</dt>
                    <dd class="col-sm-9">{{ project.madeBy ?: 'Non renseigne' }}</dd>

                    <dt class="col-sm-3">Lien</dt>
                    <dd class="col-sm-9">
                        {% if project.link %}
                            <a href="{{ project.link }}" target="_blank" rel="noopener noreferrer">{{ project.link }}</a>
                        {% else %}
                            Aucun
                        {% endif %}
                    </dd>
                </dl>

                {% if project.images %}
                    <hr>
                    <div class="project-existing-gallery">
                        {% for img in project.images %}
                            <figure class="project-existing-media-card">
                                <img
                                    src="{{ asset('uploads/images/' ~ img) }}"
                                    alt="Image {{ loop.index }} du projet {{ project.title }}"
                                    width="240"
                                    height="135"
                                    loading="lazy"
                                >
                                <figcaption class="project-existing-media-card__label">Image {{ loop.index }}</figcaption>
                            </figure>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
