{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} | Projet{% endblock %}
{% block meta_description %}{{ (project.smallDescription ?: project.description)|striptags|slice(0, 160) }}{% endblock %}
{% block canonical_url %}{{ url('project_public_show', {id: project.id}) }}{% endblock %}
{% block og_type %}article{% endblock %}
{% block og_image %}
    {{ absolute_url(project.bannerImage ? asset('uploads/images/' ~ project.bannerImage) : asset('images/projects/default-project.svg')) }}
{% endblock %}
{% block body_class %}project-page{% endblock %}

{% block body %}
    {% set fallbackProjectImage = asset('images/projects/default-project.svg') %}
    {% set bannerPath = project.bannerImage ? asset('uploads/images/' ~ project.bannerImage) : fallbackProjectImage %}
    {% set technologies = project.technologies ? project.technologies|split(',') : [] %}

    <div class="project-detail-container page-container">
        <header class="project-detail-header">
            <p class="project-detail-kicker">Projet</p>
            <h1>{{ project.title }}</h1>
            {% if project.smallDescription %}
                <p class="project-detail-small-desc">{{ project.smallDescription }}</p>
            {% endif %}
        </header>

        <div class="project-detail-content">
            <section class="project-detail-main">
                <img
                    src="{{ bannerPath }}"
                    alt="Banniere du projet {{ project.title }}"
                    class="project-detail-banner"
                    width="1200"
                    height="675"
                    decoding="async"
                >

                <div class="project-detail-description">
                    {{ project.description|nl2br }}
                </div>

                {% if technologies is not empty %}
                    <div class="project-detail-meta">
                        <strong>Technologies</strong>
                        <ul class="project-meta-list">
                            {% for technology in technologies %}
                                {% if technology|trim is not empty %}
                                    <li>{{ technology|trim }}</li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {% if project.madeBy %}
                    <div class="project-detail-meta">
                        <strong>Realise par</strong>
                        <p class="mb-0">{{ project.madeBy }}</p>
                    </div>
                {% endif %}

                {% if project.link %}
                    <div class="project-detail-link">
                        <a href="{{ project.link }}" target="_blank" rel="noopener noreferrer">Voir le projet en ligne</a>
                    </div>
                {% endif %}
            </section>

            <aside class="project-detail-side">
                {% if project.images %}
                    <div class="project-detail-gallery-section" data-project-gallery>
                        <h2>Galerie</h2>
                        <div class="project-gallery">
                            {% for img in project.images %}
                                <figure class="project-gallery__slide{% if loop.first %} is-active{% endif %}">
                                    <img
                                        src="{{ asset('uploads/images/' ~ img) }}"
                                        alt="Capture {{ loop.index }} du projet {{ project.title }}"
                                        class="project-gallery__image"
                                        width="960"
                                        height="540"
                                        loading="lazy"
                                        decoding="async"
                                    >
                                </figure>
                            {% endfor %}

                            {% if project.images|length > 1 %}
                                <button type="button" class="project-gallery__control project-gallery__control--prev" data-gallery-direction="-1" aria-label="Image precedente">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <button type="button" class="project-gallery__control project-gallery__control--next" data-gallery-direction="1" aria-label="Image suivante">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            </aside>
        </div>

        <div class="text-center">
            <a href="{{ path('app_home') }}" class="back-home-link">Retour a l accueil</a>
        </div>
    </div>
{% endblock %}
