{% extends 'base.html.twig' %}

{% block title %}Gestion des projets{% endblock %}
{% block meta_description %}Administration des projets du portfolio : creation, edition, suppression et ordre d affichage.{% endblock %}

{% block body %}
    {% set fallbackProjectImage = asset('images/projects/default-project.svg') %}

    <div class="container page-container content-fade-in project-admin-page">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                    <div>
                        <h1 class="h2 mb-1">
                            <i class="fas fa-cog me-2 text-primary"></i>
                            Gestion des projets
                        </h1>
                        <p class="text-muted mb-0">Administrez les projets affiches sur la page d accueil.</p>
                    </div>
                    <a href="{{ path('app_project_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus-circle me-2"></i>Ajouter un projet
                    </a>
                </div>

                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <h2 class="h5 mb-0">
                            <i class="fas fa-list me-2"></i>
                            Liste des projets
                        </h2>
                        {% if projects is not empty %}
                            <button id="configure-order-btn" type="button" class="btn btn-outline-success btn-sm">Configurer l ordre</button>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        {% if projects is empty %}
                            <p class="text-muted text-center py-5 mb-0">
                                <i class="fas fa-folder-open fa-3x mb-3 d-block text-secondary"></i>
                                Aucun projet configure pour le moment.
                            </p>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead>
                                        <tr>
                                            <th>Banniere</th>
                                            <th>Titre</th>
                                            <th>Description courte</th>
                                            <th>Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for project in projects %}
                                            <tr>
                                                <td>
                                                    <img
                                                        src="{{ project.bannerImage ? asset('uploads/images/' ~ project.bannerImage) : fallbackProjectImage }}"
                                                        alt="Miniature du projet {{ project.title }}"
                                                        class="project-admin-table__thumb"
                                                        width="80"
                                                        height="48"
                                                        loading="lazy"
                                                    >
                                                </td>
                                                <td>{{ project.title }}</td>
                                                <td>{{ project.smallDescription ?: 'Aucune description' }}</td>
                                                <td>{{ project.createdAt|date('d/m/Y') }}</td>
                                                <td class="project-admin-actions">
                                                    <a href="{{ path('app_project_show', {id: project.id}) }}" class="btn btn-sm btn-info" aria-label="Voir le projet {{ project.title }}">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="{{ path('app_project_edit', {id: project.id}) }}" class="btn btn-sm btn-warning" aria-label="Modifier le projet {{ project.title }}">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form method="post" action="{{ path('app_project_delete', {id: project.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce projet ?');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.id) }}">
                                                        <button class="btn btn-sm btn-danger" aria-label="Supprimer le projet {{ project.title }}">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>

                {% if projects is not empty %}
                    <section
                        id="reorder-section"
                        class="card shadow-sm mt-4"
                        hidden
                        data-project-reorder
                        data-reorder-url="{{ path('app_project_reorder') }}"
                        data-csrf-token="{{ csrf_token('project_reorder') }}"
                    >
                        <div class="card-header bg-success text-white">
                            <h2 class="h5 mb-0">
                                <i class="fas fa-arrows-alt me-2"></i>
                                Reorganiser les projets
                            </h2>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-3">Deplacez les elements a la souris ou utilisez les boutons monter / descendre avant d enregistrer.</p>

                            <div id="sortable-projects" class="list-group mb-3 project-reorder-list">
                                {% for project in projects %}
                                    <div class="list-group-item project-reorder-item" data-project-id="{{ project.id }}" draggable="true">
                                        <div class="project-reorder-item__media">
                                            <i class="fas fa-grip-vertical text-muted" aria-hidden="true"></i>
                                            <img
                                                src="{{ project.bannerImage ? asset('uploads/images/' ~ project.bannerImage) : fallbackProjectImage }}"
                                                alt="Miniature du projet {{ project.title }}"
                                                class="rounded"
                                                width="56"
                                                height="56"
                                                loading="lazy"
                                            >
                                        </div>
                                        <div class="flex-grow-1">
                                            <h3 class="h6 mb-1">{{ project.title }}</h3>
                                            <p class="text-muted small mb-0">{{ project.smallDescription ?: 'Aucune description' }}</p>
                                        </div>
                                        <div class="project-reorder-item__controls">
                                            <button type="button" class="btn btn-outline-secondary btn-sm" data-reorder-move="up" aria-label="Monter {{ project.title }}">
                                                <i class="fas fa-arrow-up"></i>
                                            </button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm" data-reorder-move="down" aria-label="Descendre {{ project.title }}">
                                                <i class="fas fa-arrow-down"></i>
                                            </button>
                                            <span class="text-muted small">Position <strong class="position-indicator">{{ loop.index }}</strong></span>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="d-flex gap-2">
                                <button id="save-order-btn" type="button" class="btn btn-success">Enregistrer l ordre</button>
                                <button id="cancel-order-btn" type="button" class="btn btn-secondary">Annuler</button>
                            </div>
                        </div>
                    </section>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
