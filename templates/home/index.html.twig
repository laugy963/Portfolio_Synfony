{% extends 'base.html.twig' %}

{% block title %}Portfolio | Accueil{% endblock %}
{% block meta_description %}Decouvrez une selection de projets Symfony, PHP et frontend moderne realises pour ce portfolio.{% endblock %}
{% block canonical_url %}{{ url('app_home') }}{% endblock %}
{% block og_type %}website{% endblock %}
{% block main_class %}main-content main-content--flush{% endblock %}

{% block body %}
    {% set fallbackProjectImage = asset('images/projects/default-project.svg') %}

    <section class="hero-banner">
        <div id="carouselBanner" class="carousel slide carousel-fade" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#carouselBanner" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Presentation du portfolio"></button>
                <button type="button" data-bs-target="#carouselBanner" data-bs-slide-to="1" aria-label="Technologies et savoir-faire"></button>
                <button type="button" data-bs-target="#carouselBanner" data-bs-slide-to="2" aria-label="Selection de projets"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="{{ asset('images/banners/banner-2-home.png') }}" class="hero-banner__image" alt="Vue d ensemble du portfolio" width="1920" height="1080" fetchpriority="high">
                </div>
                <div class="carousel-item">
                    <img src="{{ asset('images/banners/banner-1-home.png') }}" class="hero-banner__image" alt="Environnement de developpement web" width="1920" height="1080">
                </div>
                <div class="carousel-item">
                    <img src="{{ asset('images/banners/banner-3-home.png') }}" class="hero-banner__image" alt="Presentation des projets du portfolio" width="1920" height="1080">
                </div>
            </div>
        </div>

        <div class="hero-content">
            <div class="container text-center">
                <h1 class="display-2 fw-bold text-white mb-4">Portfolio Symfony et applications web sur mesure</h1>
                <p class="lead text-white mb-4">Je conçois des interfaces claires, des backends robustes et des experiences performantes pour des projets utiles.</p>
                <div class="hero-buttons">
                    <a href="#projects" class="btn btn-primary btn-lg me-3">Voir mes projets</a>
                    <a href="#contact" class="btn btn-outline-light btn-lg">Me contacter</a>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="py-5 about-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <h2 class="display-4 mb-4">A propos de moi</h2>
                    <p class="lead mb-4">Developpeur web passionne par Symfony, PHP et le frontend utile, je cree des applications maintenables, rapides et agreables a utiliser.</p>
                    <div class="skills-badges mt-4">
                        <span class="badge skill-badge me-2 mb-2">Symfony</span>
                        <span class="badge skill-badge me-2 mb-2">PHP</span>
                        <span class="badge skill-badge me-2 mb-2">JavaScript</span>
                        <span class="badge skill-badge me-2 mb-2">Twig</span>
                        <span class="badge skill-badge me-2 mb-2">Bootstrap</span>
                        <span class="badge skill-badge me-2 mb-2">Tests</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="projects" class="py-5 bg-light">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center mb-5">
                    <h2 class="display-4 mb-4">Mes projets</h2>
                    <p class="lead">Une selection courte et lisible pour garder la page d accueil rapide.</p>
                </div>
            </div>
            <div class="row">
                {% if projects is empty %}
                    <div class="col-12">
                        <p class="text-muted text-center py-5">
                            <i class="fas fa-folder-open fa-3x mb-3 d-block text-secondary"></i>
                            Aucun projet publie pour le moment.
                        </p>
                    </div>
                {% else %}
                    {% for project in projects %}
                        {% set bannerPath = project.bannerImage ? asset('uploads/images/' ~ project.bannerImage) : fallbackProjectImage %}
                        <div class="col-md-6 col-xl-4 mb-4">
                            <article class="card h-100 animate-on-scroll">
                                <img
                                    src="{{ bannerPath }}"
                                    class="card-img-top project-card__image"
                                    alt="Apercu du projet {{ project.title }}"
                                    width="640"
                                    height="360"
                                    loading="lazy"
                                    decoding="async"
                                >
                                <div class="card-body d-flex flex-column">
                                    <h3 class="card-title h5">{{ project.title }}</h3>
                                    <p class="card-text flex-grow-1">{{ project.smallDescription ?: project.description|striptags|slice(0, 140) ~ '...' }}</p>
                                    <a href="{{ path('project_public_show', {id: project.id}) }}" class="btn btn-primary align-self-start">Voir le projet</a>
                                </div>
                            </article>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </section>

    <section id="contact" class="py-5">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <h2 class="display-4 mb-4">Me contacter</h2>
                    <p class="lead mb-4">Vous avez un besoin de refonte, de maintenance Symfony ou de mise en ligne ? Parlons-en.</p>
                    <div class="d-flex justify-content-center gap-3 mb-3 flex-wrap">
                        <a href="mailto:laukingstephane@gmail.com" class="btn btn-primary">Email</a>
                        <a href="https://www.linkedin.com/in/king-lau-a2771420b" class="btn btn-outline-primary" target="_blank" rel="noopener noreferrer">LinkedIn</a>
                        <a href="https://github.com/laugy963" class="btn btn-outline-primary" target="_blank" rel="noopener noreferrer">GitHub</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
