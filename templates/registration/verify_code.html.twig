{% extends 'base.html.twig' %}

{% block title %}Verification d email{% endblock %}
{% block meta_description %}Saisissez votre code a 6 chiffres pour valider votre adresse email.{% endblock %}

{% block body %}
    <div class="container page-container verification-page">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card shadow-sm verification-card">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <h1 class="h2 mb-3">Verification d email</h1>
                            <p class="text-muted mb-2">Un code de verification a 6 chiffres a ete envoye a :</p>
                            <p class="fw-bold text-primary">{{ email }}</p>
                        </div>

                        {{ form_start(verificationForm) }}
                            <div class="mb-3">
                                {{ form_row(verificationForm.email, {
                                    attr: {
                                        class: 'form-control',
                                        readonly: true
                                    }
                                }) }}
                            </div>

                            <div class="mb-4">
                                {{ form_row(verificationForm.code, {
                                    attr: {
                                        class: 'form-control form-control-lg text-center verification-code-input',
                                        autocomplete: 'one-time-code',
                                        inputmode: 'numeric'
                                    }
                                }) }}
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">Vérifier le code</button>
                            </div>
                        {{ form_end(verificationForm) }}

                        <hr class="my-4">

                        <div class="text-center">
                            <p class="text-muted mb-2">Vous n avez pas recu le code ?</p>
                            <form method="post" action="{{ path('app_resend_code') }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('resend_verification_code') }}">
                                <button type="submit" class="btn btn-outline-secondary">Renvoyer le code</button>
                            </form>
                        </div>

                        <div class="text-center mt-3">
                            <a href="{{ path('app_register') }}" class="text-muted">Retour a l inscription</a>
                        </div>
                    </div>
                </div>

                <div class="card mt-4 border-warning verification-card">
                    <div class="card-body">
                        <h2 class="h6 text-warning mb-3">
                            <i class="fas fa-shield-alt me-2"></i>Information de securite
                        </h2>
                        <ul class="list-unstyled small text-muted mb-0">
                            <li class="mb-2"><i class="fas fa-clock text-warning me-2"></i>Le code expire dans 15 minutes.</li>
                            <li class="mb-2"><i class="fas fa-lock text-warning me-2"></i>Ne partagez jamais votre code.</li>
                            <li><i class="fas fa-envelope text-warning me-2"></i>Si vous n etes pas a l origine de cette demande, ignorez cet email.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
